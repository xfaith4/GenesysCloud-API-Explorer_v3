                  <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 6" VerticalAlignment="Center">
                    <TextBlock Text="Available topics" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <Button Name="RefreshLiveSubTopicsButton" Width="100" Height="26" Content="Refresh" Margin="8 0 0 0"/>
                  </StackPanel>
                  <TextBlock Grid.Row="1" Name="LiveSubscriptionTopicCatalogStatusText" Text="Topic catalog is empty." Foreground="Gray" FontSize="11" Margin="0 0 0 6" TextWrapping="Wrap"/>
                  <ListView Grid.Row="2" Name="LiveSubTopicCatalogList" MinHeight="180" SelectionMode="Extended"
                            VirtualizingStackPanel.IsVirtualizing="True"
                            VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ListView.View>
                      <GridView>
                        <GridViewColumn Header="Topic" DisplayMemberBinding="{Binding Name}" Width="200"/>
                        <GridViewColumn Header="Description" DisplayMemberBinding="{Binding Description}" Width="220"/>
                      </GridView>
                    </ListView.View>
                  </ListView>
                </Grid>
              </GroupBox>
              <GroupBox Header="Live analytics">
                <StackPanel>
                  <TextBlock Name="LiveSubscriptionAnalyticsStatusText" Text="Analytics idle." Foreground="Gray" FontSize="11"/>
                  <TextBlock Text="Top topics" FontWeight="Bold" Margin="0 8 0 2"/>
                  <ListView Name="LiveSubscriptionTopicTotalsList" Height="120"
                            VirtualizingStackPanel.IsVirtualizing="True"
                            VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ListView.View>
                      <GridView>
                        <GridViewColumn Header="Topic" DisplayMemberBinding="{Binding Topic}" Width="160"/>
                        <GridViewColumn Header="Count" DisplayMemberBinding="{Binding Count}" Width="70"/>
                      </GridView>
                    </ListView.View>
                  </ListView>
                  <TextBlock Text="Event type counts" FontWeight="Bold" Margin="0 10 0 2"/>
                  <ListView Name="LiveSubscriptionEventTypeTotalsList" Height="120"
                            VirtualizingStackPanel.IsVirtualizing="True"
                            VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ListView.View>
                      <GridView>
                        <GridViewColumn Header="EventType" DisplayMemberBinding="{Binding EventType}" Width="160"/>
                        <GridViewColumn Header="Count" DisplayMemberBinding="{Binding Count}" Width="70"/>
                      </GridView>
                    </ListView.View>
                  </ListView>
                </StackPanel>
              </GroupBox>
            </StackPanel>
          </Grid>
          <StackPanel Grid.Row="4" Orientation="Vertical">
            <TextBlock Name="LiveSubscriptionStatusText" Text="Subscription state idle." Foreground="SlateGray"/>
            <TextBlock Name="LiveSubscriptionCapturePathText" Text="Capture file: (none yet)" Foreground="Gray" FontSize="11"/>
          </StackPanel>
        </Grid>
      </TabItem>
      <TabItem Header="Operational Events">
        <Grid Margin="10">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0 0 12 0">
              <TextBlock Text="Event definition IDs" FontWeight="Bold" Margin="0 0 0 4"/>
              <TextBox Name="OperationalEventDefinitionsInput" Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                       VerticalScrollBarVisibility="Auto" ToolTip="Enter event definition IDs separated by commas or newlines"/>
              <StackPanel Orientation="Horizontal" Margin="0 8 0 0">
                <TextBlock Text="Topic preset" FontWeight="Bold" VerticalAlignment="Center" Margin="0 0 6 0"/>
                <ComboBox Name="OperationalEventTopicPresetCombo" MinWidth="220" Margin="0 0 8 0"/>
                <CheckBox Name="OperationalEventLiveModeCheckbox" Content="Live mode" IsChecked="True" VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock Text="Live mode consumes notification topics and may not be available on all tenants." Foreground="Gray" FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
              <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                <Button Name="RunOperationalEventsButton" Width="160" Height="32" Content="Run query"/>
                <Button Name="StopOperationalEventsLiveButton" Width="160" Height="32" Content="Stop live" Margin="10 0 0 0" IsEnabled="False"/>
              </StackPanel>
              <Button Name="ImportOperationalEventsButton" Width="220" Height="32" Content="Import events"/>
              <StackPanel Orientation="Horizontal" Margin="0 8 0 0">
                <Button Name="ExportOperationalEventsJsonButton" Width="140" Height="32" Content="Export Raw"/>
                <Button Name="ExportOperationalEventsSummaryButton" Width="140" Height="32" Content="Export Summary" Margin="10 0 0 0"/>
              </StackPanel>
              <TextBlock Name="OperationalEventsStatusText" Text="Ready to monitor operational events." Foreground="SlateGray" Margin="0 6 0 0" TextWrapping="Wrap"/>
            </StackPanel>
          </Grid>
          <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="1" CornerRadius="6" Padding="6">
            <ListView Name="OperationalEventsList" MinHeight="260"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling">
              <ListView.View>
                <GridView>
                  <GridViewColumn Header="Timestamp" Width="150" DisplayMemberBinding="{Binding Timestamp}"/>
                  <GridViewColumn Header="Event Definition" Width="180" DisplayMemberBinding="{Binding EventDefinitionId}"/>
                  <GridViewColumn Header="Severity" Width="100" DisplayMemberBinding="{Binding Severity}"/>
                  <GridViewColumn Header="Entity" Width="200" DisplayMemberBinding="{Binding EntityId}"/>
                  <GridViewColumn Header="Message" Width="320" DisplayMemberBinding="{Binding Message}"/>
                </GridView>
              </ListView.View>
            </ListView>
          </Border>
          <TextBlock Grid.Row="2" Name="OperationalEventsCatalogLink" Text="Operational Event Catalog: https://help.mypurecloud.com/articles/operational-event-catalog/" Foreground="Blue" Cursor="Hand"/>
        </Grid>
      </TabItem>
      <TabItem Header="Audit Investigator">
        <Grid Margin="10">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0 0 12 0">
              <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                <TextBlock Text="Start (UTC)" FontWeight="Bold" VerticalAlignment="Center" Margin="0 0 8 0"/>
                <TextBox Name="AuditStartInput" Width="220" Height="26"/>
                <TextBlock Text="End (UTC)" FontWeight="Bold" VerticalAlignment="Center" Margin="16 0 8 0"/>
                <TextBox Name="AuditEndInput" Width="220" Height="26"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                <TextBlock Text="Service" FontWeight="Bold" VerticalAlignment="Center" Margin="0 0 8 0"/>
                <TextBox Name="AuditServiceInput" Width="220" Height="26"/>
                <TextBlock Text="Entity ID" FontWeight="Bold" VerticalAlignment="Center" Margin="16 0 8 0"/>
                <TextBox Name="AuditEntityInput" Width="220" Height="26"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="User ID" FontWeight="Bold" VerticalAlignment="Center" Margin="0 0 8 0"/>
                <TextBox Name="AuditUserInput" Width="220" Height="26"/>
              </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1">
              <Button Name="RunAuditInvestigatorButton" Width="200" Height="32" Content="Run Audit Query"/>
              <StackPanel Orientation="Horizontal" Margin="0 8 0 0">
                <Button Name="ExportAuditJsonButton" Width="140" Height="32" Content="Export Raw"/>
                <Button Name="ExportAuditSummaryButton" Width="140" Height="32" Content="Export Summary" Margin="10 0 0 0"/>
              </StackPanel>
              <TextBlock Name="AuditStatusText" Text="Awaiting input for audit investigation." Foreground="SlateGray" Margin="0 6 0 0" TextWrapping="Wrap"/>
            </StackPanel>
          </Grid>
          <Grid Grid.Row="1" Margin="0 10 0 0">
            <Grid.RowDefinitions>
              <RowDefinition Height="2*"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <ListView Grid.Row="0" Name="AuditEventsList" VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling">
              <ListView.View>
                <GridView>
                  <GridViewColumn Header="Timestamp" Width="150" DisplayMemberBinding="{Binding Timestamp}"/>
                  <GridViewColumn Header="User" Width="180" DisplayMemberBinding="{Binding Actor}"/>
                  <GridViewColumn Header="Service" Width="140" DisplayMemberBinding="{Binding Service}"/>
                  <GridViewColumn Header="Action" Width="200" DisplayMemberBinding="{Binding Action}"/>
                  <GridViewColumn Header="Entity" Width="220" DisplayMemberBinding="{Binding EntityId}"/>
                </GridView>
              </ListView.View>
            </ListView>
            <TextBox Grid.Row="1" Name="AuditTimelineText" TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto" IsReadOnly="True" FontFamily="Consolas" FontSize="11"/>
          </Grid>
      <TextBlock Grid.Row="2" Name="AuditSummaryPathText" Text="Summary file: (none yet)" Foreground="Gray" FontSize="11"/>
        </Grid>
      </TabItem>
      <TabItem Header="Audit Log">
        <Grid Margin="10">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 8">
            <Button Name="RefreshAuditLogButton" Width="140" Height="30" Content="Refresh"/>
            <TextBlock Text="Audit log (ingest/export/retention)" VerticalAlignment="Center" Margin="10 0 0 0" Foreground="SlateGray"/>
          </StackPanel>
          <ListBox Grid.Row="1" Name="AuditLogList" ItemsSource="{Binding}" FontFamily="Consolas" FontSize="12" />
        </Grid>
      </TabItem>
	    </TabControl>
	  </Grid>
    </ScrollViewer>
  </Grid>
	</DockPanel>
	</Window>
