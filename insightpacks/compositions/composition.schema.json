{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/genesys-api-explorer/insightpacks/composition.schema.json",
  "title": "Genesys Composition Template",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "inputs",
    "steps"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": ["string", "number", "boolean", "datetime", "entityId", "interval"]
          },
          "required": { "type": "boolean" },
          "description": { "type": "string" },
          "example": {}
        },
        "additionalProperties": true
      },
      "minItems": 1
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "endpoint"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "endpoint": { "type": "string" },
          "method": {
            "type": "string",
            "enum": ["GET", "POST", "PUT", "DELETE", "PATCH"]
          },
          "dependsOn": {
            "type": "array",
            "items": { "type": "string" }
          },
          "pagination": {
            "type": "object",
            "properties": {
              "strategy": { "type": "string" },
              "cursorField": { "type": "string" },
              "pageSize": { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": true
          },
          "entityFilter": { "type": "string" },
          "bodyTemplate": {},
          "queryParameters": {
            "type": "object",
            "additionalProperties": {}
          }
        },
        "additionalProperties": true
      }
    },
    "joinKeys": {
      "type": "array",
      "items": { "type": "string" }
    },
    "normalization": {
      "type": "object",
      "properties": {
        "timestamp": {
          "type": "array",
          "items": { "type": "string" }
        },
        "eventType": {
          "type": "array",
          "items": { "type": "string" }
        },
        "entityId": {
          "type": "array",
          "items": { "type": "string" }
        },
        "severity": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "outputs": {
      "type": "object",
      "properties": {
        "summary": { "type": "string" },
        "raw": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
